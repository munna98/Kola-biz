{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:allow-open-path",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://wa.me/**" },
        { "url": "https://api.whatsapp.com/**" },
        { "url": "https://web.whatsapp.com/**" },
        { "url": "whatsapp://**" }
      ]
    }
  ]
}
